#!/bin/bash
#
# Git commit-msg hook
# 验证提交信息是否符合约定式提交规范
#
# 安装方法:
#   1. 复制此文件到 .git/hooks/commit-msg
#   2. 添加执行权限: chmod +x .git/hooks/commit-msg
#
# 或使用 Husky:
#   npx husky add .husky/commit-msg 'npx --no -- commitlint --edit "$1"'
#

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# 读取提交信息文件
COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# 定义类型
TYPES="feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert"

# 定义作用域
SCOPES="flutter-app|web-client|auth-service|push-service|media-proxy|admin-service|auth|chat|webrtc|push|media|api|ui|db|cache|docker|k8s|ci|deps|docs|security"

# 验证正则表达式
# 格式: <type>(<scope>): <subject> 或 <type>: <subject>
PATTERN="^(${TYPES})(\((${SCOPES}|[a-z0-9-]+)\))?!?:\s.+"

# 提取首行
FIRST_LINE=$(echo "$COMMIT_MSG" | head -n1)

# 验证格式
if [[ ! $FIRST_LINE =~ $PATTERN ]]; then
    echo ""
    echo -e "${RED}========================================${NC}"
    echo -e "${RED}提交信息格式错误！${NC}"
    echo -e "${RED}========================================${NC}"
    echo ""
    echo -e "${YELLOW}当前提交信息:${NC}"
    echo -e "  ${FIRST_LINE}"
    echo ""
    echo -e "${YELLOW}正确格式:${NC}"
    echo -e "  ${BLUE}<type>(<scope>): <subject>${NC}"
    echo ""
    echo -e "${YELLOW}示例:${NC}"
    echo -e "  ${GREEN}feat(auth-service): add OAuth2.0 authentication${NC}"
    echo -e "  ${GREEN}fix(web-client): resolve WebSocket reconnection issue${NC}"
    echo -e "  ${GREEN}docs: update API documentation for v1.2${NC}"
    echo ""
    echo -e "${YELLOW}可用类型:${NC}"
    echo "  feat     - 新功能"
    echo "  fix      - Bug 修复"
    echo "  docs     - 文档更新"
    echo "  style    - 代码格式"
    echo "  refactor - 代码重构"
    echo "  test     - 测试相关"
    echo "  chore    - 构建/工具"
    echo "  perf     - 性能优化"
    echo "  ci       - CI 配置"
    echo "  build    - 构建系统"
    echo "  revert   - 回滚提交"
    echo ""
    echo -e "${YELLOW}可用作用域:${NC}"
    echo "  flutter-app, web-client, auth-service, push-service, media-proxy"
    echo "  admin-service, auth, chat, webrtc, push, media, api, ui, db"
    echo "  cache, docker, k8s, ci, deps, docs, security"
    echo ""
    echo -e "${YELLOW}规范要求:${NC}"
    echo "  - 类型和作用域使用小写字母"
    echo "  - 冒号后必须有一个空格"
    echo "  - 主题首字母小写，末尾不加句号"
    echo "  - 主题长度不超过 72 个字符"
    echo ""
    exit 1
fi

# 验证主题长度
SUBJECT=$(echo "$FIRST_LINE" | sed -E "s/^(${TYPES})(\([^)]+\))?!?:\s//")
SUBJECT_LENGTH=${#SUBJECT}

if [[ $SUBJECT_LENGTH -gt 72 ]]; then
    echo ""
    echo -e "${YELLOW}警告: 主题长度 ($SUBJECT_LENGTH 字符) 超过 72 字符${NC}"
    echo ""
fi

# 验证主题首字母是否为小写
FIRST_CHAR=$(echo "$SUBJECT" | head -c 1)
if [[ $FIRST_CHAR =~ [A-Z] ]]; then
    echo ""
    echo -e "${YELLOW}警告: 主题首字母应使用小写${NC}"
    echo ""
fi

# 验证主题是否以句号结尾
if [[ $SUBJECT =~ \.$ ]]; then
    echo ""
    echo -e "${YELLOW}警告: 主题末尾不应有句号${NC}"
    echo ""
fi

echo -e "${GREEN}✓ 提交信息格式正确${NC}"
exit 0
